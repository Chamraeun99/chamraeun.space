APP_NAME="Kalapak Code Team"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
# SPA origin (OAuth redirects). Loaded via config('frontend.url'); set in production (e.g. Render).
FRONTEND_URL=http://localhost:3000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=kalapak_db
DB_USERNAME=kalapak_user
DB_PASSWORD=kalapak_secret
# Local/default: prefer (works with non-SSL postgres). Set to require for managed DBs that enforce TLS.
DB_SSLMODE=prefer

# ── Supabase PostgreSQL (secondary) — optional; used for `media` metadata table only.
# Primary DB (DB_*) stays on Neon or your main Postgres. Supabase *Storage* keys are separate (SUPABASE_* below).
# Prefer a single URL from Supabase Dashboard → Settings → Database (URI mode, with ssl).
# DB_SUPABASE_URL=postgresql://postgres.xxxx:password@aws-0-....pooler.supabase.com:6543/postgres
# Or discrete:
# DB_SUPABASE_HOST=db.xxxxx.supabase.co
# DB_SUPABASE_PORT=5432
# DB_SUPABASE_DATABASE=postgres
# DB_SUPABASE_USERNAME=postgres
# DB_SUPABASE_PASSWORD=
# DB_SUPABASE_SSLMODE=require
# DB_SUPABASE_SCHEMA=public

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

SANCTUM_STATEFUL_DOMAINS=localhost:3000

MAIL_MAILER=resend
RESEND_API_KEY=re_your_api_key_here
MAIL_FROM_ADDRESS=noreply@kalapak-team.space
MAIL_FROM_NAME="Kalapak Code Team"

# Supabase Storage (S3-compatible)
SUPABASE_ENDPOINT=https://YOUR_PROJECT_ID.supabase.co/storage/v1/s3
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ACCESS_KEY=your-anon-key
SUPABASE_SECRET_KEY=your-service-role-key
# Optional Dashboard → anon public key for `apikey` header (otherwise same as service key)
SUPABASE_ANON_KEY=
SUPABASE_BUCKET=kalapak-assets
SUPABASE_REGION=us-east-1

# Cloudflare Turnstile
TURNSTILE_SECRET_KEY= 0x4AAAAAAC4BOcvt_5BMWUI3JaB4D7dEArs

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Use /api/auth/... so the OAuth URLs share the same /api prefix as the SPA (avoids “not found” when only /api/* is routed).
GOOGLE_REDIRECT_URI=https://chamraeun-space-backend.onrender.com/api/auth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://chamraeun-space-backend.onrender.com/api/auth/github/callback
